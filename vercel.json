{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/whatsapp-webhook", "destination": "/api/whatsapp-webhook" }
  ],
  "crons": [
    {
      "path": "/api/push-alert",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/telegram-alert",
      "schedule": "*/15 * * * *"
    }
  ]
}
